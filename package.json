{
  "name": "dentflow",
  "version": "0.1.0",
  "private": true,
  "description": "DentFlow is a modern dental practice management system that helps you manage your patients, appointments, and more.",
  "author": "Nikita Bhangadiya",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "clean": "node -e \"const fs=require('fs'); const p='.next'; if(fs.existsSync(p)) fs.rmSync(p,{recursive:true}); console.log('Cleaned .next');\"",
    "start": "next start",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint",
    "db:types": "supabase gen types typescript --project-id %SUPABASE_PROJECT_ID% --schema public > src/types/database.types.ts",
    "db:push": "supabase db push"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@google/gemini-cli": "^0.33.1",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@t3-oss/env-nextjs": "^0.11.1",
    "@tanstack/react-query": "^5.59.20",
    "@vercel/analytics": "^1.4.1",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "^16.1.0",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.2",
    "recharts": "^3.8.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "eslint": "^9.15.0",
    "eslint-config-next": "^16.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3"
  }
}
